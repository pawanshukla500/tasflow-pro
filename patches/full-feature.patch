+              owner_department_id: { type: "string", description: "Department responsible for this stage." },
+              assignee_user_id: { type: "string", description: "User responsible for this stage." },
+              is_decision: { type: "boolean", description: "Stage is a yes/no decision." },
+              is_terminal: { type: "boolean", description: "Final stage (ends the workflow)." },
+            },
+            required: ["name"],
+          },
+        },
+      },
+      ["title", "stages"],
+    ),
+    handler: async ({ client, userId }, args) => {
+      const stages = Array.isArray(args.stages) ? (args.stages as Record<string, unknown>[]) : [];
+      if (stages.length === 0) throw new Error("At least one stage is required");
+
+      const { data: profile } = await client
+        .from("profiles").select("department_id").eq("id", userId).maybeSingle();
+
+      const { data: wf, error } = await client
+        .from("workflows")
+        .insert({
+          title: String(args.title),
+          description: args.description ? String(args.description) : null,
+          priority: args.priority ? String(args.priority) : "medium",
+          raised_by: userId,
+          raised_by_department_id: profile?.department_id ?? null,
+          current_stage_position: 1,
+          status: "active",
+        })
+        .select("*")
+        .single();
+      if (error) throw new Error(error.message);
+
+      const now = new Date().toISOString();
+      const stageRows = stages.map((s, i) => ({
+        workflow_id: wf.id,
+        position: i + 1,
+        name: String(s.name),
+        tat_hours: s.tat_hours !== undefined ? Number(s.tat_hours) : 24,
+        owner_department_id: s.is_terminal ? null : (s.owner_department_id ? String(s.owner_department_id) : null),
+        assignee_user_id: s.is_terminal ? null : (s.assignee_user_id ? String(s.assignee_user_id) : null),
+        is_decision: Boolean(s.is_decision),
+        is_terminal: Boolean(s.is_terminal),
+        status: i === 0 ? "in_progress" : "pending",
+        started_at: i === 0 ? now : null,
+      }));
+      const { data: inserted, error: stErr } = await client
+        .from("workflow_stages").insert(stageRows).select("id, name, position, status");
+      if (stErr) throw new Error(`Workflow created but stages failed: ${stErr.message}`);
+
+      return { id: wf.id, title: wf.title, status: wf.status, stages: inserted || [] };
+    },
+  },
+  {
+    name: "list_workflow_templates",
+    description: "List available workflow templates that can be launched into a workflow.",
+    inputSchema: objectSchema({}),
+    handler: async ({ client }) => {
+      const { data, error } = await client
+        .from("workflow_templates")
+        .select("id, name, description, category, active")
+        .eq("active", true)
+        .order("name");
+      if (error) throw new Error(error.message);
+      return data || [];
+    },
+  },
+  {
+    name: "create_workflow_from_template",
+    description: "Launch a workflow from an existing template, copying its stages.",
+    inputSchema: objectSchema(
+      {
+        template_id: { type: "string" },
+        title: { type: "string", description: "Optional title; defaults to the template name." },
+        priority: { type: "string", enum: PRIORITIES, description: "Default 'medium'." },
+      },
+      ["template_id"],
+    ),
+    handler: async ({ client, userId }, args) => {
+      const templateId = String(args.template_id);
+      const { data: tpl, error: tErr } = await client
+        .from("workflow_templates").select("id, name, description").eq("id", templateId).maybeSingle();
+      if (tErr) throw new Error(tErr.message);
+      if (!tpl) throw new Error("Template not found or not accessible");
+
+      const { data: tplStages, error: tsErr } = await client
+        .from("workflow_template_stages")
+        .select("name, position, default_tat_hours, owner_department_id, default_assignee_user_id, is_decision, is_terminal, yes_next_position, no_next_position, outcome_label")
+        .eq("template_id", templateId)
+        .order("position");
+      if (tsErr) throw new Error(tsErr.message);
+      if (!tplStages || tplStages.length === 0) throw new Error("Template has no stages");
+
+      const { data: profile } = await client
+        .from("profiles").select("department_id").eq("id", userId).maybeSingle();
+      const { data: wf, error } = await client
+        .from("workflows")
+        .insert({
+          template_id: templateId,
