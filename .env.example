# =============================================================================
# TaskFlow Pro — environment variables template
# Copy to `.env` and replace REPLACE_ME placeholders
# =============================================================================

# ─── Frontend (Vite — exposed to browser; use VITE_ prefix only) ─────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=REPLACE_ME_anon_key
VITE_APP_URL=http://localhost:8080

VITE_FIREBASE_API_KEY=REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME
VITE_FIREBASE_APP_ID=REPLACE_ME
VITE_FIREBASE_MEASUREMENT_ID=

# ─── Backend / scripts / Supabase CLI (never use VITE_ prefix) ───────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME_anon_key
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_service_role_key

FIREBASE_SERVICE_ACCOUNT_JSON_PATH=./secrets/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app

# Google Calendar user-level OAuth (Supabase Edge Function secrets)
GOOGLE_OAUTH_CLIENT_ID=REPLACE_ME_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_ME_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR_PROJECT.supabase.co/functions/v1/google-oauth-callback
GOOGLE_TOKEN_ENCRYPTION_KEY=REPLACE_ME_long_random_secret

# ─── Email (Resend) — upload with: node scripts/upload-email-secrets.mjs ─────
RESEND_API_KEY=REPLACE_ME_resend_api_key
EMAIL_FROM=noreply@youthnic.shop
EMAIL_FROM_NAME=TaskFlow Pro by VB Exports
EMAIL_LOGO_URL=https://task.youthnic.shop/youthnic-logo.svg
APP_URL=https://task.youthnic.shop

# ─── Optional ─────────────────────────────────────────────────────────────────
SUPABASE_AUTH_HOOK_SECRET=
GOOGLE_AI_API_KEY=
